# ============================================================================
# RADAR DE PRECIOS - CONFIGURACION DE AMBIENTE (FASE 4: Produccion)
# ============================================================================
# Copia este archivo a .env y completa los valores
# NUNCA hagas commit de .env a git!
# ============================================================================

# ============================================================================
# ENTORNO & DEBUG
# ============================================================================
# development | staging | production
ENVIRONMENT=development

# Desactiva debug en produccion!
DEBUG=false

# Nivel de logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO


# ============================================================================
# BASE DE DATOS
# ============================================================================
# SQLite local (desarrollo):
# DATABASE_URL=sqlite:///./data/radar_precios.db

# PostgreSQL (produccion):
# DATABASE_URL=postgresql://usuario:contrasena@host:5432/radar_precios
DATABASE_URL=postgresql://radar:radar123@localhost:5432/radar_precios


# ============================================================================
# REDIS (Cache + Task Queue)
# ============================================================================
# Local: redis://localhost:6379/0
# Con contrasena: redis://:contrasena@localhost:6379/0
# Docker: redis://:redis123@redis:6379/0
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=redis123


# ============================================================================
# CELERY (Async Task Queue)
# ============================================================================
# Broker (donde se envian las tareas)
CELERY_BROKER_URL=redis://:redis123@localhost:6379/1

# Result backend (donde se almacenan los resultados)
CELERY_RESULT_BACKEND=redis://:redis123@localhost:6379/2

# Timezone para tareas programadas
CELERY_TIMEZONE=UTC

# Usar UTC para todos los timestamps
CELERY_ENABLE_UTC=true


# ============================================================================
# RATE LIMITING
# ============================================================================
# Requests permitidos por minuto por IP
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Burst size (permitir picos temporales)
RATE_LIMIT_BURST_SIZE=15

# Ventana de tiempo en segundos
RATE_LIMIT_WINDOW_SECONDS=60


# ============================================================================
# CORS (Cross-Origin Resource Sharing)
# ============================================================================
# Lista de origenes permitidos (separados por coma)
# Dejar vacio para usar defaults: localhost:3000, localhost:8000, localhost:8001
CORS_ORIGINS=http://localhost:3000,http://localhost:8001,http://127.0.0.1:3000
# PRODUCCION: requerido - usar origen real (e.g. https://radar.tudominio.com)
# CORS_ORIGINS=https://yourdomain.com


# ============================================================================
# IP PROTECTION & PROXY ROTATION (ANTIBOT)
# ============================================================================
# Lista de proxies separados por coma. Soportan http://, https://, socks5://
# Ejemplo: http://proxy1.com:8080,http://proxy2.com:8080,socks5://proxy3.com:1080
# Dejar vacio para usar IP directa (sin proxy)
PROXIES_LIST=

# Request timeout en segundos
REQUEST_TIMEOUT=18

# Delays aleatorios entre requests (antibot)
# Min y max en segundos
ANTIBOT_DELAY_MIN=0.5
ANTIBOT_DELAY_MAX=3.0


# ============================================================================
# BUSQUEDA & SCRAPING
# ============================================================================
# API Key para Jumbo catalog API
# Obtener de: https://www.jumbo.cl (si esta disponible publicamente)
# Dejar vacio para desabilitar busqueda en Jumbo via API (fallback a scraping de HTML)
JUMBO_API_KEY=

# Cumplimiento legal/politicas:
# Por defecto NO se hacen consultas live ni crawling contra supermercados.
# Habilita LIVE_STORE_QUERIES_ENABLED solo si tienes permiso escrito,
# una API aprobada, o una base legal validada por asesor legal.
COMPLIANCE_STRICT_MODE=true
LIVE_STORE_QUERIES_ENABLED=false
STORE_CRAWLING_ENABLED=false
STORE_ROBOTS_ALLOW_ON_ERROR=false
STORE_ACCESS_CONTACT=

# Maximo de resultados de busqueda por query
MAX_RESULTS=48

# Sugerencias de autocompletado
AUTOCOMPLETE_LIMIT=6
SUGGESTION_FALLBACK_LIMIT=3

# TTL de cache en segundos
CACHE_TTL_SECONDS=180
STALE_CACHE_TTL_SECONDS=1800


# ============================================================================
# MONITOREO & RASTREO DE ERRORES (Sentry)
# ============================================================================
# Sentry DSN para rastrear errores
# Dejar vacio para desactivar Sentry
# Obtener de: https://sentry.io
SENTRY_DSN=

# Tag de environment en Sentry
SENTRY_ENVIRONMENT=development

# Sample rate para trazas (0.0-1.0): 0.1 = 10% de transacciones
SENTRY_TRACE_SAMPLE_RATE=0.1


# ============================================================================
# BACKUPS AUTOMATICOS
# ============================================================================
# Habilitar backups automaticos
BACKUP_ENABLED=true

# Intervalo de backup en horas
BACKUP_INTERVAL_HOURS=24

# Ruta de almacenamiento de backups
BACKUP_PATH=./data/backups


# ============================================================================
# METRICAS PROMETHEUS
# ============================================================================
# Habilitar endpoint de metricas Prometheus
PROMETHEUS_ENABLED=true

# Puerto para Prometheus
PROMETHEUS_PORT=9090

# Retencion de metricas en segundos
PROMETHEUS_RETENTION_SECONDS=604800


# ============================================================================
# HEADERS DE SEGURIDAD
# ============================================================================
# HSTS (HTTP Strict-Transport-Security) max age en segundos
HSTS_MAX_AGE=31536000

# Content Security Policy (CSP)
CSP_ENABLE=true

# X-Frame-Options
FRAME_OPTIONS=DENY


# ============================================================================
# SMTP (para alertas por email)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=tu-app-password
SMTP_FROM=alerts@radar.com

# Destinatarios de alertas (separados por coma)
ALERT_EMAIL_RECIPIENTS=admin@radar.com


# ============================================================================
# SLACK NOTIFICATIONS (opcional)
# ============================================================================
# URL de webhook de Slack para alertas
SLACK_WEBHOOK_URL=

# Canal de Slack (si no esta en la URL del webhook)
SLACK_CHANNEL=#alerts


# ============================================================================
# PAGERDUTY (opcional)
# ============================================================================
# Clave de integracion de PagerDuty
PAGERDUTY_INTEGRATION_KEY=


# ============================================================================
# AWS (para deployment en cloud)
# ============================================================================
# Region de AWS
AWS_REGION=us-east-1

# Bucket S3 para backups
AWS_S3_BUCKET=radar-precios-backups

# Credenciales de AWS (usar IAM roles en produccion!)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=


# ============================================================================
# JWT SEGURIDAD
# ============================================================================
# Clave secreta para firmar JWT (generar: openssl rand -base64 32)
JWT_SECRET_KEY=tu-super-clave-secreta-cambia-esto-en-produccion

# Algoritmo para JWT (HS256, RS256, etc.)
JWT_ALGORITHM=HS256

# Expiracion de token en minutos
JWT_EXPIRATION_MINUTES=60


# ============================================================================
# TRUSTED PROXIES & LOAD BALANCERS
# ============================================================================
# IPs de proxies/load balancers de confianza, separadas por coma.
# En Docker con nginx: la IP del contenedor nginx. Dejar vacio si no hay proxy.
TRUSTED_PROXY_IPS=
